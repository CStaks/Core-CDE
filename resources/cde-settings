#!/usr/bin/env python3
import json
import os
import shlex
import shutil
import subprocess
import sys
import threading
from pathlib import Path
from tkinter import StringVar, Tk, messagebox
from tkinter import ttk

SETTINGS_DIR = Path.home() / ".config" / "cde"
SETTINGS_PATH = SETTINGS_DIR / "settings.json"
ONBOARDING_DONE_PATH = SETTINGS_DIR / ".onboarding_complete"

THEME_PRESETS = {
    "dark": {
        "accent": "#7aa2f7",
        "bar_background": "#1a1b26",
        "background": "#1f2335",
        "text": "#c0caf5",
        "border_normal": "#292e42",
    },
    "light": {
        "accent": "#2f6feb",
        "bar_background": "#f2f4f8",
        "background": "#ffffff",
        "text": "#202020",
        "border_normal": "#c0c5cf",
    },
}

DEFAULTS = {
    "terminal": "kitty" if shutil.which("kitty") else "xterm",
    "file_manager": "dolphin" if shutil.which("dolphin") else "xdg-open ~",
    "launcher": "rofi -show drun -modi drun,filebrowser",
    "launcher_fullscreen": "rofi -show drun -modi drun,filebrowser -fullscreen -show-icons",
    "workspace_menu_cmd": "cde-workspaces",
    "theme": "dark",
    "update_channel": "stable",
    "accent": THEME_PRESETS["dark"]["accent"],
    "bar_background": THEME_PRESETS["dark"]["bar_background"],
    "background": THEME_PRESETS["dark"]["background"],
    "text": THEME_PRESETS["dark"]["text"],
    "border_normal": THEME_PRESETS["dark"]["border_normal"],
    "border_width": 2,
    "dock_height": 58,
}

STRING_KEYS = {
    "terminal",
    "file_manager",
    "launcher",
    "launcher_fullscreen",
    "workspace_menu_cmd",
    "theme",
    "update_channel",
    "accent",
    "bar_background",
    "background",
    "text",
    "border_normal",
}

INT_KEYS = {"border_width", "dock_height"}


def load_settings() -> dict:
    if not SETTINGS_PATH.exists():
        return DEFAULTS.copy()

    with SETTINGS_PATH.open(encoding="utf-8") as f:
        data = json.load(f)
    if not isinstance(data, dict):
        raise ValueError(f"Invalid CDE settings format in {SETTINGS_PATH}")

    settings = DEFAULTS.copy()
    for key, default in DEFAULTS.items():
        value = data.get(key)
        if isinstance(value, type(default)):
            settings[key] = value
    return settings


def save_settings(values: dict) -> None:
    SETTINGS_DIR.mkdir(parents=True, exist_ok=True)
    with SETTINGS_PATH.open("w", encoding="utf-8") as f:
        json.dump(values, f, indent=2)
        f.write("\n")


def mark_onboarding_complete() -> None:
    SETTINGS_DIR.mkdir(parents=True, exist_ok=True)
    ONBOARDING_DONE_PATH.write_text("done\n", encoding="utf-8")


def reload_cde() -> None:
    command = ["qtile", "cmd-obj", "-o", "cmd", "-f", "reload_config"]
    if not shutil.which("qtile"):
        command = [
            "python3",
            "-m",
            "libqtile.scripts.main",
            "cmd-obj",
            "-o",
            "cmd",
            "-f",
            "reload_config",
        ]
    completed = subprocess.run(command, capture_output=True, text=True, check=False)
    if completed.returncode != 0:
        raise RuntimeError(completed.stderr.strip() or "Failed to reload CDE config.")


def detect_repo_path() -> Path | None:
    candidates: list[Path] = []
    env_repo = os.environ.get("CDE_REPO_PATH")
    if env_repo:
        candidates.append(Path(env_repo).expanduser())

    script_path = Path(__file__).resolve()
    candidates.extend([script_path.parent, *script_path.parents])
    candidates.extend(
        [
            Path.cwd(),
            Path.home() / "Core-CDE",
            Path.home() / "core-cde",
            Path.home() / "CStaks" / "Core-CDE",
        ]
    )

    seen: set[Path] = set()
    for candidate in candidates:
        resolved = candidate.resolve()
        if resolved in seen:
            continue
        seen.add(resolved)
        if (resolved / ".git").exists():
            return resolved
    return None


def run_git(repo_path: Path, *args: str) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["git", "-C", str(repo_path), *args],
        capture_output=True,
        text=True,
        check=False,
    )


def get_target_branch(channel: str) -> str:
    return "main" if channel == "nightly" else "stable"


def get_update_status(channel: str) -> tuple[str, Path | None, bool, str]:
    repo_path = detect_repo_path()
    if repo_path is None:
        return (
            "No Core-CDE git checkout found. Set CDE_REPO_PATH to your repo path.",
            None,
            False,
            "",
        )

    target_branch = get_target_branch(channel)
    fetch_result = run_git(repo_path, "fetch", "--quiet", "origin")
    if fetch_result.returncode != 0:
        return (
            "Could not fetch updates for "
            f"{repo_path} ({fetch_result.stderr.strip() or 'network/remote error'}).",
            repo_path,
            False,
            target_branch,
        )

    target_ref = f"origin/{target_branch}"
    remote_target = run_git(repo_path, "rev-parse", "--verify", target_ref)
    if remote_target.returncode != 0:
        return (
            f"Channel '{channel}' requires remote branch '{target_branch}', which was not found.",
            repo_path,
            False,
            target_branch,
        )

    dirty = run_git(repo_path, "status", "--porcelain")
    local_dirty = dirty.returncode == 0 and bool(dirty.stdout.strip())
    local_head = run_git(repo_path, "rev-parse", "HEAD").stdout.strip()
    remote_head = remote_target.stdout.strip()
    merge_base = run_git(repo_path, "merge-base", "HEAD", target_ref).stdout.strip()
    current_branch = run_git(repo_path, "rev-parse", "--abbrev-ref", "HEAD").stdout.strip()

    if not local_head or not remote_head or not merge_base:
        return (
            f"Could not compare local and remote revisions for {repo_path}.",
            repo_path,
            False,
            target_branch,
        )

    if current_branch != target_branch:
        return (
            f"Update channel is '{channel}'. Update will switch branch to '{target_branch}' and overwrite local changes.",
            repo_path,
            True,
            target_branch,
        )
    if local_head == remote_head and local_dirty:
        return (
            "Remote is current, but local changes exist. Update will reset to origin and discard local changes.",
            repo_path,
            True,
            target_branch,
        )
    if local_head == remote_head:
        return f"Up to date on {target_branch} ({repo_path}).", repo_path, False, target_branch
    if local_head == merge_base:
        return (
            f"Update available: local branch is behind origin/{target_branch}.",
            repo_path,
            True,
            target_branch,
        )
    if remote_head == merge_base:
        return (
            f"Local branch is ahead of origin/{target_branch}. Update will reset to origin/{target_branch}.",
            repo_path,
            True,
            target_branch,
        )
    return (
        f"Local and origin/{target_branch} have diverged. Update will reset to origin/{target_branch}.",
        repo_path,
        True,
        target_branch,
    )


def launch_update_terminal(repo_path: Path, terminal_command: str, target_branch: str) -> None:
    terminal_parts = shlex.split(terminal_command)
    if not terminal_parts:
        raise RuntimeError("Terminal command is empty.")

    update_script = (
        f"set -e; cd {shlex.quote(str(repo_path))}; "
        "git fetch --quiet origin; "
        f"git checkout {shlex.quote(target_branch)} 2>/dev/null || "
        f"git checkout -b {shlex.quote(target_branch)} origin/{shlex.quote(target_branch)}; "
        f"git reset --hard origin/{shlex.quote(target_branch)}; "
        "git clean -fd; "
        "./setup.sh; "
        "echo; "
        "read -n 1 -s -r -p 'Update finished. Press any key to close...'"
    )
    subprocess.Popen(terminal_parts + ["-e", "bash", "-lc", update_script])


def main() -> None:
    settings = load_settings()
    onboarding_mode = (
        os.environ.get("CDE_ONBOARDING") == "1"
        or "--onboarding" in sys.argv
        or not ONBOARDING_DONE_PATH.exists()
    )

    root = Tk()
    root.title("CDE Settings")
    root.geometry("860x620")
    root.resizable(False, False)

    root_frame = ttk.Frame(root, padding=14)
    root_frame.pack(fill="both", expand=True)

    if onboarding_mode:
        ttk.Label(root_frame, text="Welcome to CDE", font=("sans", 15, "bold")).pack(anchor="w")
        ttk.Label(
            root_frame,
            text="Use these sections to configure your desktop. Start with General and Appearance.",
        ).pack(anchor="w", pady=(2, 10))

    notebook = ttk.Notebook(root_frame)
    notebook.pack(fill="both", expand=True)

    general_tab = ttk.Frame(notebook, padding=12)
    appearance_tab = ttk.Frame(notebook, padding=12)
    launcher_tab = ttk.Frame(notebook, padding=12)
    updates_tab = ttk.Frame(notebook, padding=12)
    advanced_tab = ttk.Frame(notebook, padding=12)

    notebook.add(general_tab, text="General")
    notebook.add(appearance_tab, text="Appearance")
    notebook.add(launcher_tab, text="Launchers")
    notebook.add(updates_tab, text="Updates")
    notebook.add(advanced_tab, text="Advanced")

    values_var = {key: StringVar(value=str(settings.get(key, DEFAULTS[key]))) for key in DEFAULTS}
    theme_var = StringVar(value=settings.get("theme", DEFAULTS["theme"]))
    channel_var = StringVar(value=settings.get("update_channel", DEFAULTS["update_channel"]))
    update_status = StringVar(value="Update status: not checked")

    ui_state = {"busy": False, "update_result": None}

    def add_labeled_entry(parent: ttk.Frame, row: int, label: str, key: str, width: int = 52) -> None:
        ttk.Label(parent, text=label).grid(row=row, column=0, sticky="w", pady=6)
        ttk.Entry(parent, textvariable=values_var[key], width=width).grid(row=row, column=1, sticky="ew", pady=6)

    general_tab.columnconfigure(1, weight=1)
    add_labeled_entry(general_tab, 0, "Terminal app", "terminal")
    add_labeled_entry(general_tab, 1, "File manager app", "file_manager")
    ttk.Label(general_tab, text="Update channel").grid(row=2, column=0, sticky="w", pady=6)
    channel_frame = ttk.Frame(general_tab)
    channel_frame.grid(row=2, column=1, sticky="w", pady=6)
    ttk.Radiobutton(channel_frame, text="Stable", variable=channel_var, value="stable").pack(side="left")
    ttk.Radiobutton(channel_frame, text="Nightly", variable=channel_var, value="nightly").pack(side="left", padx=(12, 0))

    appearance_tab.columnconfigure(1, weight=1)
    ttk.Label(appearance_tab, text="Theme").grid(row=0, column=0, sticky="w", pady=6)
    theme_frame = ttk.Frame(appearance_tab)
    theme_frame.grid(row=0, column=1, sticky="w", pady=6)
    ttk.Radiobutton(theme_frame, text="Dark", variable=theme_var, value="dark").pack(side="left")
    ttk.Radiobutton(theme_frame, text="Light", variable=theme_var, value="light").pack(side="left", padx=(12, 0))
    add_labeled_entry(appearance_tab, 1, "Accent color", "accent")
    add_labeled_entry(appearance_tab, 2, "Dock background color", "bar_background")
    add_labeled_entry(appearance_tab, 3, "Desktop background color", "background")
    add_labeled_entry(appearance_tab, 4, "Primary text color", "text")
    add_labeled_entry(appearance_tab, 5, "Border color", "border_normal")

    launcher_tab.columnconfigure(1, weight=1)
    add_labeled_entry(launcher_tab, 0, "Quick launcher command (Super+Space)", "launcher")
    add_labeled_entry(launcher_tab, 1, "Fullscreen launcher command", "launcher_fullscreen")
    add_labeled_entry(launcher_tab, 2, "Workspace menu command", "workspace_menu_cmd")

    updates_tab.columnconfigure(0, weight=1)
    ttk.Label(
        updates_tab,
        text="Update CDE force-syncs to remote and discards local repo changes.",
        wraplength=760,
    ).grid(row=0, column=0, sticky="w", pady=(0, 10))

    update_buttons = ttk.Frame(updates_tab)
    update_buttons.grid(row=1, column=0, sticky="w")
    check_btn = ttk.Button(update_buttons, text="Check for Updates")
    update_btn = ttk.Button(update_buttons, text="Update CDE")
    check_btn.pack(side="left")
    update_btn.pack(side="left", padx=(10, 0))

    ttk.Label(updates_tab, textvariable=update_status, wraplength=760).grid(
        row=2, column=0, sticky="w", pady=(10, 0)
    )

    advanced_tab.columnconfigure(1, weight=1)
    add_labeled_entry(advanced_tab, 0, "Window border width", "border_width")
    add_labeled_entry(advanced_tab, 1, "Dock height", "dock_height")

    def apply_theme_preset() -> None:
        preset = THEME_PRESETS.get(theme_var.get())
        if preset is None:
            return
        for key, value in preset.items():
            values_var[key].set(value)

    ttk.Button(appearance_tab, text="Apply Theme Preset Colors", command=apply_theme_preset).grid(
        row=6, column=1, sticky="w", pady=(10, 0)
    )

    def collect_values() -> dict:
        values: dict[str, object] = {}
        for key in STRING_KEYS:
            values[key] = values_var[key].get().strip()
        for key in INT_KEYS:
            raw = values_var[key].get().strip()
            try:
                parsed = int(raw)
            except ValueError as err:
                raise RuntimeError(f"{key} must be a number.") from err
            if parsed <= 0:
                raise RuntimeError(f"{key} must be greater than 0.")
            values[key] = parsed

        values["theme"] = theme_var.get()
        values["update_channel"] = channel_var.get()
        return values

    def set_busy(value: bool) -> None:
        ui_state["busy"] = value
        state = "disabled" if value else "normal"
        check_btn.configure(state=state)
        update_btn.configure(state=state)
        save_btn.configure(state=state)
        save_reload_btn.configure(state=state)
        defaults_btn.configure(state=state)
        root.configure(cursor="watch" if value else "")

    def save(reload_now: bool) -> None:
        try:
            values = collect_values()
        except RuntimeError as err:
            messagebox.showerror("CDE Settings", str(err))
            return

        save_settings(values)
        if onboarding_mode:
            mark_onboarding_complete()
        if reload_now:
            try:
                reload_cde()
            except RuntimeError as err:
                messagebox.showerror("CDE Settings", str(err))
                return
            messagebox.showinfo("CDE Settings", "Saved and reloaded CDE config.")
            return
        messagebox.showinfo("CDE Settings", "Saved CDE settings.")

    def check_updates_async() -> None:
        if ui_state["busy"]:
            return
        set_busy(True)
        update_status.set("Update status: checking...")

        def worker() -> None:
            status, repo_path, available, branch = get_update_status(channel_var.get())

            def done() -> None:
                set_busy(False)
                update_status.set(f"Update status: {status}")
                ui_state["update_result"] = (repo_path, available, branch)

            root.after(0, done)

        threading.Thread(target=worker, daemon=True).start()

    def run_update() -> None:
        result = ui_state.get("update_result")
        if result is None:
            check_updates_async()
            messagebox.showinfo("CDE Settings", "Checking update status first. Click Update CDE again in a moment.")
            return

        repo_path, available, branch = result
        if repo_path is None:
            messagebox.showerror("CDE Settings", "No repository found for updates.")
            return
        if not available:
            messagebox.showinfo("CDE Settings", "No update action needed right now.")
            return

        proceed = messagebox.askyesno(
            "CDE Settings",
            "Update CDE will force-sync to the remote branch and discard local repo changes. Continue?",
        )
        if not proceed:
            return

        terminal_cmd = values_var["terminal"].get().strip() or DEFAULTS["terminal"]
        try:
            launch_update_terminal(repo_path, terminal_cmd, branch)
        except (RuntimeError, FileNotFoundError) as err:
            messagebox.showerror("CDE Settings", str(err))
            return
        messagebox.showinfo(
            "CDE Settings",
            f"Started {channel_var.get()} update in a terminal. Enter your sudo password there if prompted.",
        )

    def restore_defaults() -> None:
        for key, value in DEFAULTS.items():
            values_var[key].set(str(value))
        theme_var.set(DEFAULTS["theme"])
        channel_var.set(DEFAULTS["update_channel"])
        update_status.set("Update status: defaults restored (not saved yet).")

    check_btn.configure(command=check_updates_async)
    update_btn.configure(command=run_update)

    footer = ttk.Frame(root_frame)
    footer.pack(fill="x", pady=(10, 0))
    defaults_btn = ttk.Button(footer, text="Restore Defaults", command=restore_defaults)
    save_btn = ttk.Button(footer, text="Save", command=lambda: save(False))
    save_reload_btn = ttk.Button(footer, text="Save + Reload", command=lambda: save(True))
    defaults_btn.pack(side="left")
    save_reload_btn.pack(side="right")
    save_btn.pack(side="right", padx=(0, 10))

    root.mainloop()


if __name__ == "__main__":
    main()
